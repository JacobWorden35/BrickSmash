<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How to Play"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn the rules, power-ups, and scoring."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTROLS"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Drag your finger across the screen to move the paddle\n• Tap to launch the ball at the start of each life\n• Use left and right arrow keys on emulator/keyboard"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRICK TYPES"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Normal — 1 hit to destroy (100 base points)\n• Hardened — 2 hits to destroy (250 base points)\n• Indestructible — gray blocks that cannot be broken"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POWER-UPS"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Power-ups occasionally drop from destroyed bricks. Catch them with your paddle to activate:\n\n• WIDE — your paddle grows larger (stacks each pickup)\n• FIRE — ball passes through bricks without bouncing\n• SLOW — ball speed is temporarily reduced\n• MULTI — spawns 2 extra balls (stacks each pickup)\n\nActive power-ups show under your paddle with a shrinking timer bar."
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORING"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Base points per brick are multiplied by your combo multiplier\n• Combo builds +0.1x per consecutive hit (capped at 5.0x)\n• Combo resets when the ball touches your paddle or after 2 seconds without a hit\n• End-of-level bonus: +1000 per remaining life plus a speed bonus up to +5000\n• Clear faster with more lives and higher combos for top scores!"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>