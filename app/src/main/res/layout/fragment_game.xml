<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.bricksmash.game.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar with pause/back buttons — extra top padding to clear status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="40dp"
        android:paddingEnd="12dp"
        android:paddingStart="12dp">

        <ImageButton
            android:id="@+id/btnPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Pause" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Level Complete Overlay -->
    <LinearLayout
        android:id="@+id/overlayComplete"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level Clear!"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:id="@+id/tvCompleteScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextLevel"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Next Level"
            android:layout_marginTop="32dp"
            app:cornerRadius="24dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToMenu"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Back to Menu"
            android:layout_marginTop="8dp"
            app:cornerRadius="24dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

    <!-- Game Over Overlay -->
    <LinearLayout
        android:id="@+id/overlayGameOver"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game Over"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FF5252" />

        <TextView
            android:id="@+id/tvGameOverScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Retry"
            android:layout_marginTop="32dp"
            app:cornerRadius="24dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGameOverBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Back to Menu"
            android:layout_marginTop="8dp"
            app:cornerRadius="24dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

</FrameLayout>